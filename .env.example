# Copy this file to .env and fill in your actual keys
ANTHROPIC_API_KEY=sk-ant-...
ALPHA_VANTAGE_KEY=your_key_here
NEWS_API_KEY=your_key_here
SENDGRID_API_KEY=SG...
RECIPIENT_EMAIL=your@email.com

# SMTP（Gmail 应用专用密码，替代 SendGrid）
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Massive / Polygon-compatible market data
MASSIVE_API_KEY=
MASSIVE_BASE_URL=https://api.massive.com
MASSIVE_WS_URL=wss://delayed.massive.com/stocks
# Plan tier controls WebSocket usage: basic/eod/starter → WS disabled (EOD data only)
# Set to "realtime" or "developer" to enable live minute-bar WebSocket
MASSIVE_PLAN=basic

# Web Dashboard
WEB_USER=admin
# Generate hash: python -c "from passlib.context import CryptContext; print(CryptContext(schemes=['bcrypt']).hash('your_password'))"
WEB_PASS_HASH=
WEB_SECRET_KEY=change-me-to-a-random-32-char-string
